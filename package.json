{
  "name": "simple-email-client-x",
  "version": "1.0.0",
  "description": "A lightweight cross-platform email client built with Electron",
  "main": "src/main/main.js",
  "author": "ASimpUsr",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:setup": "electron-builder --win nsis"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "electron-store": "^8.2.0",
    "i18next": "^23.11.5",
    "imapflow": "^1.0.163",
    "mailparser": "^3.7.1",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1"
  },
  "build": {
    "appId": "com.asimpusr.simpleemailclientx",
    "productName": "Simple Email Client X",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Simple Email Client X"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "protocols": [
      {
        "name": "MailTo",
        "schemes": [
          "mailto"
        ],
        "role": "Editor"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true
  }
}
